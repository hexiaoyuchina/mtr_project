# 现网 VR 101.89.68.109 — 部署环境变量
# 用法：复制为同目录 env（勿提交 Git），至少填写 MTR_OP_SSH_PASSWORD
#
# 【必填】
MTR_OP_HOST=101.89.68.109
MTR_OP_SSH_USER=root
MTR_OP_SSH_PASSWORD=t$7kaptj+A)J89NB

# 【远端路径 / 端口】
MTR_OP_REMOTE_DIR=/root/mtr_op
MTR_OP_PORT=8808
MTR_PROBE_SSH_HOST=101.89.68.109

# 【BGP — 与 docs/部署.md、BGP_OP_NETWORK.md 一致；现场不同时改】
LOCAL_AS=63199
RR_AS=63199
ROUTER_ID=139.159.43.207
RR_ADDR=139.159.43.249
MTR_DOWNSTREAM_REMOTE_AS=63199
MTR_SATELLITE_PEER_IP=139.159.43.208

# 【网口 — 数据面分工勿混用】
# RR 上行：enp59s0f0np0 → 207，对 249
MTR_BGP_RR_UPLINK_IFACE=enp59s0f0np0
# 上下联二层隔离：下联 iv249 挂 249/32（可 ping；勿与上联同广播域时开）
MTR_BGP_RR_SPOOF_IPVLAN_ADDR=1
# 下游 / 卫星 ipvlan 父口：eno1np0，对 208
MTR_OP_DOWNSTREAM_IFACE=eno1np0
# 下联口本机 IPv4（仅 eno1np0，非上联）
MTR_DOWNSTREAM_ADDR=139.159.43.209/24
MTR_BGP_IPVLAN_BASE_IFACE=eno1np0
MTR_BGP_IPVLAN_PEER_IP=139.159.43.208

# 【下联 transit — python 109/apply_downstream_transit.py】
# 去程 2110 pref30；回程 2111 pref29 to 105.92/30；105.94 邻居 MAC 同 208
MTR_DOWNSTREAM_RETURN_TABLE=2111
MTR_DOWNSTREAM_RETURN_PREFIX=139.159.105.92/30
MTR_DOWNSTREAM_TO_CLIENT_RULE_PREF=29
MTR_DOWNSTREAM_CLIENT_NEIGH_HOSTS=139.159.105.94
# 105.94 与 208 同机双 IP，内核不会 ARP；须 permanent 邻居（apply 脚本会写）

MTR_BGP_IPVLAN_AUTO=1
MTR_SATELLITE_BGP_TCP_SOURCE=spoof
MTR_BGP_RIB_SYNC=1
MTR_BGP_RIB_SYNC_SEC=60

# 角色提示（未写入库时 UI 用）；RR 请在 BGP 管理里建在 gobgp-rr，勿写 default 预设
MTR_BGP_ROLE_MAP=139.159.43.249:rr,139.159.43.208:downstream
# MTR_BGP_DB_PRESETS=   # 留空：不自动灌邻居；现网 RR 仅保留 gobgp-rr 行

# 【ICMP TE 改写 — iptables mangle FORWARD → te_rewrite_nfqueue】
# 未设置时 te_rewrite_sync 从 MTR_BGP_* 推断；显式写可避免仍绑实验室 ens192/ens224
MTR_TE_REWRITE_OIF=eno1np0
MTR_TE_REWRITE_IIF=enp59s0f0np0
# 本机发出的 TE（如第 1 跳 209→105.94）走 OUTPUT NFQUEUE；0 关闭
# MTR_TE_REWRITE_OUTPUT=1
# 可选探测 SNAT（默认关 MTR_TE_PROBE_RETURN_VIA_200）；现网下游源一般为 208
# MTR_TE_PROBE_SRC=139.159.43.208
# MTR_TE_RETURN_IP=139.159.43.207

# 【Agent 存储】
REDIS_ADDR=localhost:6379
ROCKSDB_PATH=/var/lib/bgp_agent/rocksdb
API_ADDR=:9179
# bgp-agent：默认本机编译上传，不在 VR 上 go build
MTR_DEPLOY_BGP_AGENT_PREBUILT=1
MTR_DEPLOY_BUILD_BGP_AGENT=0
# 部署前强制本机重编：MTR_DEPLOY_BGP_AGENT_LOCAL_BUILD=1
# 仅上传已有二进制、不自动编译：MTR_DEPLOY_BGP_AGENT_LOCAL_BUILD=0
# 恢复 VR 编译（不推荐）：MTR_DEPLOY_BUILD_BGP_AGENT=1 且 MTR_DEPLOY_BGP_AGENT_PREBUILT=0
# Windows 首次编译：tools/setup_bgp_agent_build.ps1 或 python tools/bgp_agent_build.py
# MTR_BGP_AGENT_BUILD_REMOTE=0

# 【部署控制 — 通常留空；日常发版用 tools/deploy_light.py】
# MTR_OP_SKIP_INSTALL=1
# MTR_OP_PRESERVE_DIR=1
