# Linux 200 实验室 — 部署/校验环境变量（source 或 deploy.ps1 加载）
# 不修改仓库根目录其它文件；仅本目录脚本使用。

MTR_OP_HOST=10.133.151.200
MTR_OP_SSH_USER=root
MTR_OP_SSH_PASSWORD=1234qwer
MTR_OP_REMOTE_DIR=/root/mtr_op
MTR_OP_PORT=8808
MTR_PROBE_SSH_HOST=10.133.151.200
# 逐跳 TE 在 Linux 200 FORWARD NFQUEUE；勿默认 SNAT（邻近跳对 152.200 回包失败会致 mtr 第 2 跳 ???）
MTR_TE_PROBE_RETURN_VIA_200=0
MTR_TE_PROBE_SRC=10.133.152.204
MTR_TE_RETURN_IP=10.133.152.200
MTR_TE_REWRITE_IIF=ens224
# MTR_TE_REWRITE_PEER_HOSTS=

LOCAL_AS=63199
ROUTER_ID=10.133.153.200
RR_ADDR=10.133.153.204
RR_AS=63199
MTR_DOWNSTREAM_REMOTE_AS=63199

MTR_BGP_IPVLAN_AUTO=1
MTR_BGP_IPVLAN_BASE_IFACE=ens192
MTR_BGP_RR_UPLINK_IFACE=ens224
MTR_BGP_SAT_DNAT_IIF=1
MTR_BGP_IPVLAN_PEER_IP=10.133.152.204
MTR_SATELLITE_PEER_IP=10.133.152.204
MTR_SATELLITE_PHY_VRF=default
MTR_AUTO_SATELLITE_VRF=note
MTR_AUTO_SATELLITE_VRF_NOTE=BGPSAT
MTR_BGP_RIB_SYNC=1
MTR_BGP_RIB_SYNC_SEC=60

MTR_BGP_ROLE_MAP=10.133.153.204:rr,10.133.152.204:downstream
# 勿把 152.204 写入 default 预设，否则会多一条无 source_ip 的重复邻居
MTR_BGP_DB_PRESETS=default:10.133.153.204:rr

REDIS_ADDR=localhost:6379
ROCKSDB_PATH=/var/lib/bgp_agent/rocksdb
API_ADDR=:9179

# 首次无 Go 时可设为 0，仅同步代码与 unit、沿用已有二进制
MTR_DEPLOY_BUILD_BGP_AGENT=1

# 部署/Agent 重启后：OP 等待 Agent 健康并从 data.db 恢复 BGP（秒）
MTR_BGP_STARTUP_RESTORE=1
MTR_BGP_AGENT_RESTORE_MAX_SEC=600

# 邻居列表不做百万级 RIB 计数，避免单 worker OP 卡死、/health 超时
MTR_BGP_NEIGHBORS_FAST_LIST=1
MTR_BGP_NEIGHBORS_AGENT_TIMEOUT=12
